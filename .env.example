# ---------------------------------------------------------------------------
# Application under test
# ---------------------------------------------------------------------------
BASE_URL=https://app.example.com
LOGIN_URL=https://app.example.com/login

# Default URL list for `autocoder generate` and `autocoder extend` when
# no positional URLs and no --urls-file are supplied.
# Priority on the CLI is always: positional args > --urls-file > AUTOCODER_URLS.
#
# Comma-separated single line (recommended for .env files):
# AUTOCODER_URLS=https://app.example.com/login,https://app.example.com/dashboard
#
# …or newline-separated using a quoted multi-line value (# comments allowed):
# AUTOCODER_URLS="
# https://app.example.com/login
# https://app.example.com/dashboard
# # https://app.example.com/reports   (commented out)
# "

# Login credentials (NEVER commit real values; keep them in .env, not .env.example)
LOGIN_USERNAME=
LOGIN_PASSWORD=
LOGIN_OTP_SECRET=

# Optional: an alternate user for RBAC scenarios
RBAC_USERNAME=
RBAC_PASSWORD=

# ---------------------------------------------------------------------------
# Local LLM (Phi-4 14B via Ollama)  — see info/13_docker_phi4_setup.md
# ---------------------------------------------------------------------------
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=phi4:14b
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_NUM_CTX=12288
OLLAMA_TEMPERATURE=0.2
OLLAMA_TOP_P=0.9
# Output token cap. Feature plans for pages with many scenarios can exceed
# 512 tokens; truncated JSON makes the validator fail. 2048 is a safe floor
# for Phi-4 14B (16K context).
OLLAMA_NUM_PREDICT=2048

# ---------------------------------------------------------------------------
# Orchestrator
# ---------------------------------------------------------------------------
# Where to put the manifest/registry that drives resume + extension
AUTOCODER_MANIFEST_DIR=manifest

# Where Playwright stores authenticated session state
STORAGE_STATE=.auth/user.json

# Browser controls used by the orchestrator while it explores pages
HEADLESS=true
EXTRACTION_TIMEOUT_MS=20000
EXTRACTION_NAV_TIMEOUT_MS=30000
PW_WORKERS=2

# Extraction caps (keep tight — controls token spend)
MAX_ELEMENTS_PER_PAGE=60
MAX_DEPENDENCY_DEPTH=3

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Console + manifest/runs.log floor. One of: debug | info | warn | error.
# Use `debug` for selector-pick traces, per-element decisions, raw plan dumps.
LOG_LEVEL=info
